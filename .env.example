# ======================================================
# DRISHTI — AI Smart Traffic Intelligence Platform
# Environment Variables Template
# Copy this file to .env.local and fill in your values
# ======================================================

# ── Firebase Authentication ──────────────────────────
# Get these from: https://console.firebase.google.com/
# Project Settings > General > Your apps > Web app
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# ── Admin Access Control ─────────────────────────────
# Option 1 – Environment variable whitelist (static):
# Comma-separated list of email addresses allowed to access /master-admin.
# If not set, falls back to the hardcoded list in app/master-admin/page.tsx
# NEXT_PUBLIC_ADMIN_EMAILS=admin@city.gov,traffic.control@city.gov

# Option 2 – Firestore `admins` collection (dynamic, recommended):
# Create a document in the `admins` Firestore collection for each admin user.
# The document ID should be the Firebase Auth UID (preferred) or the user's
# lowercased email address. The document can contain any fields (e.g. role, name).
# Example (Firebase Console > Firestore > admins > {uid}):
#   { "email": "admin@example.com", "role": "traffic_admin" }
# Users present in this collection are granted admin access regardless of the
# NEXT_PUBLIC_ADMIN_EMAILS list above.

# ── Supabase (Optional — for persistent database) ────
# If not set, mock data will be used automatically
# Get from: https://app.supabase.com/
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# NOTE: Google Maps API is no longer required.
# The platform now uses Leaflet.js + OpenStreetMap (100% free, no API key needed).
